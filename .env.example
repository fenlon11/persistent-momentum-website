# Persistent Momentum — corporate site + pmOS Command Center dashboard
# Copy to .env.local for local dev. Set the same vars in Vercel for production.

# ===============================================
# Main site Supabase (contact form submissions)
# ===============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-main-site-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===============================================
# pmOS platform Supabase (dashboard reads live data from here)
# Project: klrrjnzpkvdlfucjrasy — the authoritative pmOS data layer.
# Tables read by the dashboard:
#   pm_memories, pm_session_logs, pm_telemetry, pm_skill_invocations
#   worker_registry, worker_activity_logs, cc_task_queue
#   products, product_metrics_daily, product_events
#   ame_brand_configs, ame_content_queue, ame_content_performance
# ===============================================
PMOS_SUPABASE_URL=https://klrrjnzpkvdlfucjrasy.supabase.co
PMOS_SUPABASE_SERVICE_KEY=your-pmos-service-role-key

# ===============================================
# Dashboard auth (PIN gate on /dashboard)
# Pick any numeric PIN. Matt-only.
# ===============================================
DASHBOARD_PIN=your-6-digit-pin

# ===============================================
# Contact form email (Resend)
# ===============================================
RESEND_API_KEY=your-resend-api-key
NOTIFICATION_EMAIL=your-email@persistentmomentum.com
